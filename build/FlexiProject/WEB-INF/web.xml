<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ========================
         SERVLETS
    ======================== -->

    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>servlet.SignupServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>servlet.ProductServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>CustomerServlet</servlet-name>
        <servlet-class>servlet.CustomerServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>SupplierServlet</servlet-name>
        <servlet-class>servlet.SupplierServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>PaymentServlet</servlet-name>
        <servlet-class>servlet.PaymentServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>InvoiceServlet</servlet-name>
        <servlet-class>servlet.InvoiceServlet</servlet-class>
    </servlet>

    <!-- ========================
         URL MAPPINGS (IMPORTANT)
    ======================== -->

    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/api/signup</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/login</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/api/product</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>CustomerServlet</servlet-name>
        <url-pattern>/api/customer</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>SupplierServlet</servlet-name>
        <url-pattern>/api/supplier</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>PaymentServlet</servlet-name>
        <url-pattern>/api/payment</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>InvoiceServlet</servlet-name>
        <url-pattern>/api/invoice</url-pattern>
    </servlet-mapping>

    <!-- ========================
         SESSION CONFIG
    ======================== -->

    <session-config>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ========================
         WELCOME FILE
         (So /FlexiProject opens index.html automatically)
    ======================== -->

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>